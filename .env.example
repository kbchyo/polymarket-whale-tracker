# Polymarket Whale Tracker — Environment Configuration
# Copy this file to .env and fill in your values

# Required: comma-separated whale wallet addresses to track
WHALE_ADDRESSES=0x...

# Feed mode: poll | ws | hybrid | shadow
FEED_MODE=hybrid

# Paper trading
PAPER_TRADE_SIZE_USDC=20
STARTING_BANKROLL_USDC=50   # set to 0 to disable bankroll mode

# Signal filtering
MIN_USDC_SIZE=20
MIN_WHALE_NOTIONAL_USDC=10
MAX_TRADE_AGE_MS=180000
COPY_ONLY_WHALE_BUYS=false

# Risk controls
STOP_LOSS_PCT=8
TAKE_PROFIT_PCT=12
STALE_CLOSE_MS=900000
FLIP_SUPPRESS_MS=10000
MAX_OPEN_POSITIONS=0
MAX_DAILY_LOSS_USDC=50
MAX_DAILY_STAKE_USDC=0
MAX_LOSS_PER_POSITION_USDC=20
MARKET_POSITION_CAP_USDC=25

# Signal deduplication / cooldown
SIGNAL_COOLDOWN_MS=1000
TOP_N_WEIGHTED_POSITIONS=0

# WebSocket (required for FEED_MODE=ws or hybrid)
# POLYMARKET_WS_URL=wss://...
# POLYMARKET_WS_ASSET_IDS=id1,id2,...
WS_TRIGGER_COOLDOWN_MS=180

# Polling
POLL_MS=2000
WHALE_TRADE_FETCH_LIMIT=5

# State persistence
STATE_FILE=.state/bot-state.json

# Live trading (disabled by default — paper only)
LIVE_TRADING=false
